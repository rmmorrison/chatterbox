# Copy to .env on the host alongside docker-compose.traefik.yml.
# These values configure the SHARED Traefik instance — one per host, in
# its own deploy directory, serving every chatterbox stack on the host.

# Email used for LetsEncrypt registration / expiry notices.
# Both the production and staging resolvers use this value.
LETSENCRYPT_EMAIL=replace-me@example.com
