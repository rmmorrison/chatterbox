# Copy to .env on the host alongside docker-compose.shared.yml.
# These values configure the shared infrastructure (Traefik today; future
# additions land here too) — one stack per host, in its own deploy
# directory, serving every chatterbox application stack on the host.

# Traefik — email used for LetsEncrypt registration / expiry notices.
# Both the production and staging resolvers use this value.
LETSENCRYPT_EMAIL=replace-me@example.com
